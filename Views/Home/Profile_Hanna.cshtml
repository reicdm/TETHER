@{
    ViewData["Title"] = "Profile - Hanna";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pf_hanna.css" />
}

<div style="display:flex; gap:.5rem;">
    <button type="" class="btn-back">← Back</button>
</div>

<div>
    <div class="d-flex justify-content-center align-items-center" style="min-height: 85vh;">
        <div class="card p-5 text-center profile-container">
                <div class="profile-avatar">
                    <img src="~/images/member-image/default.jpg" alt="Johanna Angela P. Estalilla" />
                </div>

                <div class="profile-card-body">
                    <h2 class="text-uppercase profile-title">Johanna Angela P. Estalilla</h2>
                    <h4 class="mb-5 text-uppercase role-title">Back-end Developer</h4>

                    <div class="profile-input-group text-start">
                        <label class="profile-label">Personal Email</label>
                        <input type="email" class="profile-form-control" placeholder="sample@gmail.com" readonly />
                    </div>

                    <div class="profile-input-group text-start">
                        <label class="profile-label">School Email</label>
                        <input type="email" class="profile-form-control" placeholder="sample@gmail.com" readonly />
                    </div>

                    <div class="profile-input-group text-start">
                        <label class="profile-label">Github</label>
                        <input type="email" class="profile-form-control" placeholder="sample@gmail.com" readonly />
                    </div>
                </div>
        </div>
    </div>

</div>
