@model TETHER.Models.CalendarViewModel
@{
    ViewData["Title"] = "Calendar";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/calendar.css" />
}

<div class="mb-5">
    <h1 class="page-title">Calendar</h1>
</div>

<div class="page-layout">
    <div class="calendar-cont">
        <div class="grid-nav">
            <a class="btn-month" asp-action="Calendar" asp-route-year="@Model.Prev.Year" asp-route-month="@Model.Prev.Month">← @Model.Prev.ToString("MMM")</a>
            <span class="grid-month-title">@Model.MonthName</span>
            <a class="btn-month" asp-action="Calendar" asp-route-year="@Model.Next.Year" asp-route-month="@Model.Next.Month">@Model.Next.ToString("MMM") →</a>
        </div>

        <div class="calendar-card">
            <div class="weekday-header">
                @foreach (var d in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                {
                    <span>@d</span>
                }
            </div>

            <div class="calendar-grid">
                @for (int i = 0; i < Model.FirstDayOfWeek; i++)
                {
                    <div class="cal-cell empty"></div>
                }

                @for (int d = 1; d <= Model.DaysInMonth; d++)
                {
                    <div class="cal-cell @(Model.Entries.ContainsKey(d) ? "filled" : "")">
                        <span class="cal-day">@d</span>

                        @if (Model.Entries.TryGetValue(d, out var entries))
                        {
                            <div class="cal-entries">
                                @foreach (var e in entries)
                                {
                                    string priorityClass = e.Priority switch
                                    {
                                        "High" => "card-high",
                                        "Medium" => "card-medium",
                                        "Low" => "card-low",
                                        _ => ""
                                    };

                                    string titleClass = e.Priority switch
                                    {
                                        "High" => "title-high",
                                        "Medium" => "title-medium",
                                        "Low" => "title-low",
                                        _ => ""
                                    };

                                    <a class="cal-chip @priorityClass"
                                       asp-action="UpdateTask"
                                       asp-route-id="@e.Id"
                                       title="@($"{e.Title} — {e.Priority} — {e.AssignedTo}")">
                                        <span class="chip-label @titleClass">@e.Title</span>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="todo-cont">
        <h2 class="todo-title">To-do List</h2>
        <div class="todo-card">
            @foreach (var dayEntries in Model.Entries.OrderBy(kv => kv.Key))
            {
                foreach (var e in dayEntries.Value)
                {
                    string priorityClass = e.Priority switch
                    {
                        "High" => "card-high",
                        "Medium" => "card-medium",
                        "Low" => "card-low",
                        _ => ""
                    };

                    string dateClass = e.Priority switch
                    {
                        "High" => "date-high",
                        "Medium" => "date-medium",
                        "Low" => "date-low",
                        _ => ""
                    };
                     
                    <a class="task-card @priorityClass"
                       asp-action="UpdateTask"
                       asp-route-id="@e.Id">
                        <span class="date-title @dateClass text-uppercase">@e.Date.ToString("MMM d")</span>
                        <div class="task-title">@e.Title</div>
                        <span class="badge-priority text-uppercase">@e.Priority</span>
                    </a>
                }
            }
        </div>
    </div>
</div>