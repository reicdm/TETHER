@model IEnumerable<TETHER.Models.TaskItem>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";

    var currentRole = ViewBag.Role as string;
    bool isPM = (currentRole == "PM");
    string currentUser = ViewBag.CurrentUser ?? "";

    var assignedTasks = Model.Where(t => t.Status == "Assigned" || t.Status == "Pending" || t.Status == "Progress").ToList();
    var pendingTasks = Model.Where(t => t.AssignedTo == currentUser && t.Status == "Pending").ToList();
    var progressTasks = Model.Where(t => t.AssignedTo == currentUser && t.Status == "Progress").ToList();
    var doneTasks = Model.Where(t => t.AssignedTo == currentUser && t.Status == "Done").ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="page-title">Task Distribution</h1>

    @if (isPM)
    {
        <a class="btn btn-dash text-uppercase px-4 py-2 text-white" asp-action="AddTask">
            <i class="bi bi-plus-lg me-1"></i> New Task
        </a>
    }
</div>

<!-- KANBAN BOARD: TASKS -->
<div class="kanban-board">

    <!-- COLUMN 1: ASSIGNED TASKS -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">Assigned Tasks</span>
            <span class="column-count">@assignedTasks.Count</span>
        </div>
        @foreach (var task in assignedTasks)
        {
            <div class="task-card card-@task.Priority.ToLower()" data-id="@task.Id">
                <div class="task-title">@task.Title</div>
                <span class="badge-priority text-uppercase">@task.Priority</span>
            </div>
        }
    </div>

    <!-- COLUMN 2: PENDING -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">Pending</span>
            <span class="column-count">@pendingTasks.Count</span>
        </div>
        @foreach (var task in pendingTasks)
        {
            <div class="task-card card-@task.Priority.ToLower()" data-id="@task.Id">
                <div class="task-title">@task.Title</div>
                <span class="badge-priority text-uppercase">@task.Priority</span>
            </div>
        }
    </div>

    <!-- COLUMN 3: IN PROGRESS -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">In Progress</span>
            <span class="column-count">@progressTasks.Count</span>
        </div>
        @foreach (var task in progressTasks)
        {
            <div class="task-card card-@task.Priority.ToLower()" data-id="@task.Id">
                <div class="task-title">@task.Title</div>
                <span class="badge-priority text-uppercase">@task.Priority</span>
            </div>
        }
    </div>

    <!-- COLUMN 4: DONE -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">Done</span>
            <span class="column-count">@doneTasks.Count</span>
        </div>
        @foreach (var task in doneTasks)
        {
            <div class="task-card card-@task.Priority.ToLower()" data-id="@task.Id">
                <div class="task-title">@task.Title</div>
                <span class="badge-priority text-uppercase">@task.Priority</span>
            </div>
        }
    </div>

</div>