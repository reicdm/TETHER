@model IEnumerable<TETHER.Models.Entities.TaskItem>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";

    var currentRole = ViewBag.Role as string;
    bool isPM = (currentRole == "PM");
    int currentUserId = ViewBag.CurrentUserId ?? 0;

    var assignedTasks = Model.Where(t => t.Status != null && (t.Status.Name == "Pending" || t.Status.Name == "In Progress")).ToList();
    var pendingTasks = Model.Where(t => t.Status != null && t.Status.Name == "Pending" && t.Assignments.Any(a => a.AssignedTo == currentUserId)).ToList();
    var progressTasks = Model.Where(t => t.Status != null && t.Status.Name == "In Progress" && t.Assignments.Any(a => a.AssignedTo == currentUserId)).ToList();
    var doneTasks = Model.Where(t => t.Status != null && t.Status.Name == "Completed" && t.Assignments.Any(a => a.AssignedTo == currentUserId)).ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h1 class="page-title">Task Distribution</h1>

    @if (isPM)
    {
        <button class="btn text-uppercase px-4 py-2 text-white" style="background-color: var(--primary-red); border-radius: 8px; font-size:0.85rem; font-weight: 700;">
            <i class="bi bi-plus-lg me-1"></i> New Task
        </button>
    }
</div>

<!-- KANBAN BOARD: TASKS -->
<div class="kanban-board">

    <!-- COLUMN 1: ASSIGNED TASKS -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">Assigned Tasks</span>
            <span class="column-count">@assignedTasks.Count</span>
        </div>
        @foreach (var task in assignedTasks)
        {
            <div class="task-card" data-id="@task.Id">
                <div class="task-title">@task.Name</div>
                <span class="badge-priority text-uppercase">@(task.PriorityLevel?.Name ?? "N/A")</span>
            </div>
        }
    </div>

    <!-- COLUMN 2: PENDING -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">Pending</span>
            <span class="column-count">@pendingTasks.Count</span>
        </div>
        @foreach (var task in pendingTasks)
        {
            <div class="task-card" data-id="@task.Id">
                <div class="task-title">@task.Name</div>
                <span class="badge-priority text-uppercase">@(task.PriorityLevel?.Name ?? "N/A")</span>
            </div>
        }
    </div>

    <!-- COLUMN 3: IN PROGRESS -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">In Progress</span>
            <span class="column-count">@progressTasks.Count</span>
        </div>
        @foreach (var task in progressTasks)
        {
            <div class="task-card" data-id="@task.Id">
                <div class="task-title">@task.Name</div>
                <span class="badge-priority text-uppercase">@(task.PriorityLevel?.Name ?? "N/A")</span>
            </div>
        }
    </div>

    <!-- COLUMN 4: DONE -->
    <div class="kanban-column">
        <div class="column-header">
            <span class="column-title text-uppercase">Done</span>
            <span class="column-count">@doneTasks.Count</span>
        </div>
        @foreach (var task in doneTasks)
        {
            <div class="task-card" data-id="@task.Id">
                <div class="task-title">@task.Name</div>
                <span class="badge-priority text-uppercase">@(task.PriorityLevel?.Name ?? "N/A")</span>
            </div>
        }
    </div>

</div>