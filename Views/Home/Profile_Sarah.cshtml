@model TETHER.Models.Entities.TeamMember
@{
    ViewData["Title"] = "Profile - Sarah";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pf_sara.css" />
}

<div style="display:flex; gap:.5rem;">
    <a asp-action="Dashboard" asp-controller="Home" class="btn-back">← Back</a>
</div>

<div class="d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="card p-5 text-center profile-container">
        <div class="profile-avatar">
            <img src="@Model.ProfileImageUrl" alt="Sarah Mae D.C. Harina" />
        </div>

        <div class="profile-card-body">
            <h2 class="text-uppercase profile-title">Sarah Mae D.C. Harina</h2>
            <h4 class="mb-5 text-uppercase role-title">Front-end Developer</h4>

            <div class="profile-input-group text-start">
                <label class="profile-label">Personal Email</label>
                <input type="email" class="profile-form-control" value="@Model.PersonalGmail" placeholder="sample@gmail.com" readonly />
            </div>

            <div class="profile-input-group text-start">
                <label class="profile-label">School Email</label>
                <input type="email" class="profile-form-control" value="@Model.SchoolGmail" placeholder="sample@gmail.com" readonly />
            </div>

            <div class="profile-input-group text-start">
                <label class="profile-label">Github</label>
                <input type="text" class="profile-form-control" value="@Model.GithubUsername" placeholder="github-username" readonly />
            </div>
        </div>
    </div>
</div>