<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TETHER</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TETHER.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="margin: 0; padding: 0; background-color: var(--bg-black);">

    <div class="dashboard-wrapper">
        <aside class="sidebar">
            <div class="d-flex align-items-center gap-2 px-2">
                <div style="width: 24px; height: 24px; background-color: var(--primary-red); border-radius: 6px;"></div>
                <h4 class="m-0 text-uppercase tracking-wider text-white" style="font-size: 1.2rem; font-weight: 800; letter-spacing: 0.05em;">TETHER</h4>
            </div>

            <ul class="nav-menu">
                <li>
                    <a asp-action="Dashboard" asp-controller="Home" asp-route-role="@Context.Request.Query["role"]"
                       class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a asp-action="Calendar" asp-controller="Home"
                       class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Calendar" ? "active" : "")">
                        <i class="bi bi-calendar3"></i> Calendar
                    </a>
                </li>
                <li>
                    <a asp-action="Team" asp-controller="Home"
                       class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Team" ? "active" : "")">
                        <i class="bi bi-people"></i> My Team
                    </a>
                </li>
            </ul>

            <a asp-action="Index" asp-controller="Home" class="btn btn-logout text-uppercase text-center w-100">
                Logout
            </a>
        </aside>

        <main class="main-content">
            <header class="top-navbar">
                <div style="width: 120px;" class="d-none d-lg-block"></div>

                <a asp-action="Profile" asp-controller="Home"
                   class="d-flex align-items-center gap-2 text-decoration-none"
                   style="width: 120px; justify-content: flex-end;">
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                        <i class="bi bi-person-fill text-dark"></i>
                    </div>
                    <span class="text-white" style="font-size: 0.9rem; font-weight: 500;">Profile</span>
                </a>
            </header>

            <div class="content-body">
                @RenderBody()
            </div>

        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>